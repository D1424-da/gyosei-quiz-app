rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function matchesAuthUid(uid) {
      return signedIn() && uid is string && uid == request.auth.uid;
    }

    function ownsResource() {
      return signedIn() && resource != null && resource.data.uid is string && resource.data.uid == request.auth.uid;
    }

    function ownsRequest() {
      return signedIn() && request.resource != null && request.resource.data.uid is string && request.resource.data.uid == request.auth.uid;
    }

    function isAdminEmail() {
      return signedIn() && request.auth.token.email is string &&
        request.auth.token.email in ['ikeda.job08@gmail.com'];
    }

    // User profile
    match /users/{uid} {
      allow read, write: if matchesAuthUid(uid);
    }

    // Question set
    // - shared doc: /question_sets/shared (all signed-in users can read, admin email can write)
    // - legacy doc: /question_sets/{uid} (kept for migration compatibility)
    match /question_sets/{docId} {
      allow read: if (docId == 'shared' && signedIn()) || matchesAuthUid(docId) || ownsResource();
      allow create, update, delete: if (docId == 'shared' && isAdminEmail()) || matchesAuthUid(docId) || ownsRequest() || ownsResource();
    }

    // Study time per user (doc id = auth uid)
    match /study_stats/{uid} {
      allow read: if matchesAuthUid(uid) || ownsResource();
      allow create, update, delete: if matchesAuthUid(uid) || ownsRequest() || ownsResource();
    }

    // Records collection supports both:
    // - current format: /records/{uid} (doc id equals uid)
    // - legacy format:  /records/{autoId} with field uid
    match /records/{recordId} {
      allow read: if matchesAuthUid(recordId) || ownsResource();
      allow create, update, delete: if matchesAuthUid(recordId) || ownsRequest() || ownsResource();
    }
  }
}
