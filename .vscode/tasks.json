			"args": [
				"-NoProfile",
				"-Command",
				"$q=(Get-Content .\\output\\gyosyo_h30_questions.json -Raw | ConvertFrom-Json)[0]; function Normalize-KataCombo([string]$Text){ if([string]::IsNullOrWhiteSpace($Text)){ return '' }; return ([regex]::Replace($Text,'[^アイウエオカキクケコ]','')) }; function Test-ComboOptionText([string]$Text){ if([string]::IsNullOrWhiteSpace($Text)){ return $false }; $compact=Normalize-KataCombo $Text; if([string]::IsNullOrWhiteSpace($compact)){ return $false }; return ($compact -match '^[アイウエオカキクケコ]{2,5}$') }; $selectedIndex=[int]$q.correctOption; $selectedText=[string]$q.limbs[$selectedIndex-1].text; 'selectedText=' + $selectedText; 'selectedOk=' + (Test-ComboOptionText $selectedText); $questionText=$q.questionText; $patterns=@('(?ms)(?:^|\\n)\\s*([アイウエオカキクケコ])[\\s　\\.．、,:：\\-]+\\s*(.+?)(?=(?:\\n\\s*[アイウエオカキクケコ][\\s　\\.．、,:：\\-]+)|\\z)','(?ms)([アイウエオカキクケコ])[\\s　\\.．、,:：\\-]+\\s*(.+?)(?=(?:[\\s　]*[アイウエオカキクケコ][\\s　\\.．、,:：\\-]+)|\\z)'); foreach($pat in $patterns){ $hits=[regex]::Matches($questionText,$pat); 'pat hits=' + $hits.Count; foreach($h in $hits){ $h.Groups[1].Value + ':' + $h.Groups[2].Value } if($hits.Count -gt 0){ break } }; $lines=@($questionText -split '\\r?\\n'); 'lineCount=' + $lines.Count; foreach($line in $lines){ if($line -match '^\\s*([アイウエオカキクケコ])[\\s　\\.．、,:：-]+(.+)$'){ $Matches[1] + ':' + $Matches[2] } }"
			],
