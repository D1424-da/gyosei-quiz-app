		{
			"label": "debug kata statement regex",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"$q = (Get-Content .\\output\\gyosyo_h30_questions.json -Raw | ConvertFrom-Json)[0].questionText; $lines = $q -split '\\r?\\n'; $pat1 = '^\\s*([アイウエオカキクケコ])[\\s　\\.．、,:：-]+(.+)$'; $pat2 = '(?ms)(?:^|\\n)\\s*([アイウエオカキクケコ])[\\s　\\.．、,:：\\-]+\\s*(.+?)(?=(?:\\n\\s*[アイウエオカキクケコ][\\s　\\.．、,:：\\-]+)|\\z)'; $hits1 = @(); foreach($l in $lines){ if($l -match $pat1){ $hits1 += $Matches[1] + ':' + $Matches[2] } }; $hits2 = [regex]::Matches($q,$pat2) | ForEach-Object { $_.Groups[1].Value + ':' + $_.Groups[2].Value }; 'LINES=' + $lines.Count; 'HITS1=' + $hits1.Count; $hits1; 'HITS2=' + @($hits2).Count; $hits2"
			],
			"isBackground": false,
			"problemMatcher": [],
			"group": "build"
		},
